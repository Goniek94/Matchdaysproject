# ──────────────────────────────────────────────────────────────────────────────
# Matchdays Frontend — environment variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to source control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Backend API ───────────────────────────────────────────────────────────────
# Full URL of the NestJS API (including /api/v1).
# WebSocket base URL is derived automatically by stripping /api/v1.
NEXT_PUBLIC_API_URL=https://your-backend.example.com/api/v1

# ── Supabase Storage ──────────────────────────────────────────────────────────
# Found in your Supabase project → Settings → API.
# The anon/public key is safe to expose in the browser.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-domain.example.com

# ── Node environment ─────────────────────────────────────────────────────────
# Set by your hosting provider; rarely needs to be set manually.
# NODE_ENV=production
